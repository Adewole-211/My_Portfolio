   "metadata": {},
   "outputs": [],
   "source": [
    "# Outbound Performance by Facility and Quarter\n",
    "plt.figure(figsize=(20, 5))\n",
    "ax = sns.barplot(x='facility_code', y='performance_score', hue='quarter', data=outbound_q1_summary, errorbar=None)\n",
    "plt.xlabel(\"Facility Code\")\n",
    "plt.ylabel(\"Performance Score\")\n",
    "plt.title(\"Outbound Performance by Facility and Quarter\")\n",
